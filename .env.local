AWS_REGION=ap-northeast-2

# DynamoDB Local endpoint (docker-compose)
DYNAMODB_ENDPOINT=http://dynamodb-local:8998

# Dummy credentials for LocalStack/DynamoDB Local
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy

# App auth secret (change per-team)
JWT_SECRET=CHANGE_ME

# S3 bucket name to auto-create in LocalStack
S3_BUCKET_NAME=test-bucket

# Browser-accessible endpoint for S3 when running locally (used by presign URLs)
S3_PUBLIC_ENDPOINT=http://localhost:4566

MAX_UPLOAD_SIZE_MB=25

# Gemini
# Put a real key or set SUMMARIZE_USE_MOCK=true
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# LocalStack endpoints (inside containers)
# For host-run, use http://localhost:4566 instead
SQS_ENDPOINT=http://localstack:4566
SUMMARIZE_SQS_QUEUE_URL=http://localstack:4566/000000000000/echoai-summarize-queue
SUMMARIZE_ASYNC=true
SUMMARIZE_USE_MOCK=true
SUMMARIZE_MODEL=gemini-2.0-flash-lite
