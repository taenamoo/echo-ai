{
    "name": "Echo AI Dev Container",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "api-local",
    "runServices": [
        "dynamodb-local",
        "localstack",
        "dynamodb-init",
        "ai-processor",
        "api-local",
        "spa",
        "dynamodb-admin"
    ],
    "runArgs": [
        "--dns=8.8.8.8",
        "--dns=8.8.4.4"
    ],
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "bradlc.vscode-tailwindcss",
                "google.geminicodeassist",
                "esbenp.prettier-vscode",
                "eamodio.gitlens",
                "oderwat.indent-rainbow"
            ]
        }
    },
    "remoteEnv": {
        "NODE_ENV": "development"
    },
    "overrideCommand": false,
    "postCreateCommand": "echo 'Devcontainer ready. Use pnpm dev or docker-compose services.'",
    
}
