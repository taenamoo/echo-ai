{
    "name": "Echo AI Dev Container",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "bradlc.vscode-tailwindcss",
                "google.geminicodeassist",
                "esbenp.prettier-vscode",
                "eamodio.gitlens",
                "oderwat.indent-rainbow"
            ]
        }
    },
    "remoteEnv": {
        "NODE_ENV": "development"
    }
}